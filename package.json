{
  "name": "three-mf",
  "version": "1.1.1",
  "description": "A comprehensive TypeScript library for parsing and working with 3D Manufacturing Format (3MF) files.",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "author": "watzon <cawatson1993@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/watzon/three-mf.git"
  },
  "bugs": {
    "url": "https://github.com/watzon/three-mf/issues"
  },
  "homepage": "https://github.com/watzon/three-mf#readme",
  "keywords": [
    "3mf",
    "3d-printing",
    "typescript",
    "parser",
    "additive-manufacturing",
    "mesh",
    "opc"
  ],
  "packageManager": "bun@1.3.14",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./production-extension": {
      "types": "./dist/production-extension/index.d.ts",
      "import": "./dist/production-extension/index.js"
    },
    "./materials-extension": {
      "types": "./dist/materials-extension/index.d.ts",
      "import": "./dist/materials-extension/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "test": "bun test",
    "dev": "bun run --watch index.ts",
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "build:watch": "tsc -w -p tsconfig.build.json",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jszip": "^3.4.1",
    "stl": "^1.1.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "fast-xml-parser": "^4.1.4",
    "jszip": "^3.10.1",
    "uuid": "^11.1.0"
  }
}